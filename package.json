{
  "name": "@sniebauer/zendesk-mcp",
  "version": "0.1.0",
  "description": "Local MCP server exposing Zendesk Support, Macros, attachments, and Help Center reads to Claude Desktop and Claude Code. 23 tools.",
  "type": "module",
  "bin": {
    "zendesk-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "setup": "node dist/index.js setup",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "zendesk",
    "claude",
    "claude-desktop",
    "claude-code",
    "support",
    "help-center"
  ],
  "author": "Steve Niebauer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sniebauer/zendesk-mcp.git"
  },
  "homepage": "https://github.com/sniebauer/zendesk-mcp#readme",
  "bugs": {
    "url": "https://github.com/sniebauer/zendesk-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "node-zendesk": "^5.0.13",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
